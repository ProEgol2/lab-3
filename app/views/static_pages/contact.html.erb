<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link rel="stylesheet" href="app/assets/stylesheets/styles.css">

        <script>
            function submitted(){
                const div = document.createElement("div");
                div.className = "alert alert-light alert-dismissible fade show";
                div.setAttribute("role", "alert");
                div.innerText = "Thank you for your message, we will contact you soon.";

                const btn = document.createElement("button");
                btn.className = "btn-close";
                btn.setAttribute("type", "button");
                btn.setAttribute("data-bs-dismiss", "alert");
                btn.setAttribute("aria-label", "Close");
                
                div.appendChild(btn);
                document.getElementById("alertdiv").appendChild(div);
            }

        </script>
        <title>Y</title>
    </head>
    <body>
        <div class="container">
            <div class="row align-items-start">
                <div id = "col1" class="col-2 d-flex flex-column justify-content-between">
                    <%=image_tag("Raccoon2.png", class: "Raccoon img-fluid mb-5", id:"Raccoon1")%>
                </div>
                <div class="col-8">
                    <h1 id="Title" class="border-bottom border-dark text-center"> Contact us</h1>
                    <div id="alertdiv"></div>
                    <form class="row g-3">
                        <div class="col-md-6">
                            <label for="inputPassword4" class="form-label">Name</label>
                            <input type="text" class="form-control" id="inputPassword4">
                        </div>
                        <div class="col-md-6">
                            <label for="inputEmail4" class="form-label">Email</label>
                            <input type="email" class="form-control" id="inputEmail4">
                        </div>
                        <div class="mb-3">
                            <label for="exampleFormControlTextarea1" class="form-label">Message</label>
                            <textarea class="form-control" id="exampleFormControlTextarea1" rows="3"></textarea>
                        </div>
                        <div class="col-auto">
                            <button onclick = submitted() type="button" class="btn btn-primary">Submit</button>
                        </div>
                    </form>
                </div>
                <div class="col-2 d-flex flex-column justify-content-between">
                    <%=image_tag("Raccoon2.png", class: "Raccoon img-fluid mb-5 flip", id:"Raccoon1")%>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </body>
</html>